# ============================================================
# Chariot environment variables (copy to .env.local and fill in)
# .env.local is gitignored and must never be committed (NF-2).
# Only NEXT_PUBLIC_* values are exposed to the browser (AC-5).
# ============================================================

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only; bypasses RLS — never expose

# ── Stripe ──
STRIPE_SECRET_KEY=                  # server-only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # client-safe publishable key (must not be the pk_test_51Dummy placeholder)
STRIPE_WEBHOOK_SECRET=              # server-only; verifies webhook signatures (PAY-2)
STRIPE_WEBHOOK_SECRET_PREV=         # OPTIONAL: previous webhook secret during 24h rotation overlap

# ── Pricing ──
DROP0_PRICE_CENTS=2000              # $20.00 Founding Member spot

# ── Email (Resend) ──
RESEND_API_KEY=                     # server-only
RESEND_FROM_EMAIL=no-reply@chariotarchive.com           # transactional sender (order confirmations, auth)
RESEND_SUPPORT_FROM_EMAIL=Chariot Support <support@chariotarchive.com>   # contact-form sender (separate so domain attribution stays clean)
SUPPORT_TO_EMAIL=caleb@chariotarchive.com               # inbox the support contact form forwards to

# ── PII hashing ──
EMAIL_HASH_PEPPER=                  # server-only; rotate-safe pepper for audit-log email/IP hashing. Generate with `openssl rand -hex 32`.

# ── Cron ──
CRON_SECRET=                        # bearer token guarding /api/cron/reconcile (M5)

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://chariotarchive.com
