# ============================================================
# Chariot environment variables (copy to .env.local and fill in)
# .env.local is gitignored and must never be committed (NF-2).
# Only NEXT_PUBLIC_* values are exposed to the browser (AC-5).
# ============================================================

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only; bypasses RLS — never expose

# ── Stripe ──
STRIPE_SECRET_KEY=                  # server-only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # client-safe publishable key
STRIPE_WEBHOOK_SECRET=              # server-only; verifies webhook signatures (PAY-2)

# ── Pricing ──
DROP0_PRICE_CENTS=2000              # $20.00 Founding Member spot

# ── Email (Resend) ──
RESEND_API_KEY=                     # server-only
RESEND_FROM_EMAIL=no-reply@chariotarchive.com   # single transactional sender (EMAIL-1)

# ── Cron ──
CRON_SECRET=                        # bearer token guarding /api/cron/reconcile (M5)

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://chariotarchive.com
